# PubMed / NCBI — increases rate limit from 3 to 10 req/s
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Email for CrossRef polite pool and Unpaywall (required by Unpaywall)
MY_EMAIL=your@email.com

# HTTP defaults (optional — shown with package defaults)
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Zotero — create a key at https://www.zotero.org/settings/keys
# Your userID is shown at the top of that page.
# For group libraries, use the group ID from the URL: https://www.zotero.org/groups/XXXXXXX/group_name
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user