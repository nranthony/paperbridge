@article{hu_from_2024,
	title = {From lab to life: Evaluating the reliability and validity of psychophysiological data from wearable devices in laboratory and ambulatory settings},
	volume = {56},
	issn = {1554-3528},
	doi = {10.3758/s13428-024-02387-3},
	abstract = {Despite the increasing popularity of ambulatory assessment, the reliability and validity of psychophysiological signals from wearable devices is unproven in daily life settings. We evaluated the reliability and validity of physiological signals (ECG, PPG, EDA) collected from two wearable devices (Movisens EcgMove4 and Empatica E4) in the lab (N=67) and daily life (N=20) among adults aged 18–64 with Mindware as the laboratory gold standard. Results revealed that both wearable devices' valid data rates in daily life were lower than in the laboratory. Movisens EcgMove4 provided more reliable and valid HRV measurements than Empatica E4 in both settings.},
	number = {7},
	journal = {Behavior Research Methods},
	publisher = {Springer Science and Business Media LLC},
	author = {Hu, Xin and Sgherza, Tanika R. and Nothrup, Jessie B. and Fresco, David M. and Naragon-Gainey, Kristin and Bylsma, Lauren M.},
